#!/usr/bin/env bash
# meowkit-slug — output project slug and sanitized branch name
# Adapted from gstack-slug for MeowKit. No external dependencies.
# Usage: eval "$(meowkit-slug)"  → sets SLUG and BRANCH variables
set -euo pipefail
RAW_SLUG=$(git remote get-url origin 2>/dev/null | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1|;s|.*[:/]\([^/]*/[^/]*\)$|\1|' | tr '/' '-')
RAW_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '-')
SLUG=$(printf '%s' "$RAW_SLUG" | tr -cd 'a-zA-Z0-9._-')
BRANCH=$(printf '%s' "$RAW_BRANCH" | tr -cd 'a-zA-Z0-9._-')
echo "SLUG=${SLUG:-unknown}"
echo "BRANCH=${BRANCH:-unknown}"
