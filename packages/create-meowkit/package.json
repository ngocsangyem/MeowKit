{
  "name": "create-meowkit",
  "version": "0.1.0",
  "description": "Scaffold a MeowKit AI agent toolkit for your project",
  "type": "module",
  "bin": {
    "create-meowkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build:templates": "node scripts/build-templates.mjs",
    "build": "npm run build:templates && npx tsc",
    "prepublishOnly": "npm run build",
    "dev": "npx tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "picocolors": "^1.1.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meowkit/meowkit"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "toolkit",
    "tdd",
    "cli"
  ]
}
