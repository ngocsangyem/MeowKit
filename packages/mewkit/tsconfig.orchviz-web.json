{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node", "react", "react-dom"],
		"baseUrl": "src/orchviz-web",
		"paths": { "@/*": ["./*"] }
	},
	"include": [
		"src/orchviz-web/**/*.ts",
		"src/orchviz-web/**/*.tsx",
		"src/orchviz/protocol.ts"
	]
}
