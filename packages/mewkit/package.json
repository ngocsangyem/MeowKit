{
  "name": "mewkit",
  "version": "1.8.0",
  "description": "MeowKit CLI — scaffold, upgrade, and manage your AI agent toolkit",
  "type": "module",
  "bin": {
    "meowkit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "npx tsc",
    "build:web": "npx tsc -p tsconfig.orchviz-web.json --noEmit && npx vite build --config vite.config.orchviz-web.ts && node scripts/check-bundle-budget.cjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "dev": "npx tsc --watch"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@iarna/toml": "^2.2.5",
    "adm-zip": "^0.5.17",
    "diff": "^5.2.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.0",
    "semver": "^7.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/react": "^16.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/d3-force": "^3.0.10",
    "@types/diff": "^5.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.0",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react": "^4.7.0",
    "d3-force": "^3.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.5.0",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
