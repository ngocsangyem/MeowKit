# MeowKit starter exec-policy rules for Codex (EXPERIMENTAL — the rules feature may change).
#
# Defense-in-depth ONLY. These are never the sole enforcement: the MeowKit CLI gate and
# the PreToolUse hooks remain authoritative. Project-local rules load only when the
# project `.codex/` layer is trusted, so an untrusted or older Codex simply ignores this
# file (graceful fallback). Each rule PROMPTS (requires approval) before a high-impact
# command — it never silently allows. Precedence when several match: forbidden > prompt > allow.
#
# Syntax verified against `codex execpolicy check` (codex-cli). Extend with your own
# project policies; keep the starter set small.

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "prompt",
    justification = "Force-push can overwrite remote history — require explicit approval.",
    match = ["git push --force origin main"],
    not_match = ["git push origin main"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "Hard reset discards uncommitted work — require explicit approval.",
    match = ["git reset --hard HEAD~1"],
    not_match = ["git reset HEAD"],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "prompt",
    justification = "Recursive force-delete is destructive — require explicit approval.",
    match = ["rm -rf build"],
    not_match = ["rm file.txt"],
)
