{
  "name": "meowkit-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w packages/mewkit run build",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "tsc --noEmit -p packages/mewkit/tsconfig.json",
    "format": "npx prettier --write \"packages/*/src/**/*.{ts,js,json}\"",
    "format:check": "npx prettier --check \"packages/*/src/**/*.{ts,js,json}\"",
    "test": "vitest run",
    "release:check": "bash scripts/release-check.sh",
    "sync-versions": "node scripts/sync-versions.cjs",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9.5.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "semantic-release": "^24.2.9",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "version": "2.14.5",
  "overrides": {
    "npm": "^11.14.1"
  }
}
