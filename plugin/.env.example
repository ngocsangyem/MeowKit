# MeowKit Environment Variables
# Copy to .claude/.env and fill in values.
# .env is gitignored — secrets stay local.
#
# Precedence (highest to lowest):
#   1. shell export         (session-specific overrides)
#   2. .claude/.env         (this file — secrets + personal prefs)
#   3. settings.json "env"  (team-shared defaults, git-committed)
#
# Values MUST be unquoted UNLESS they contain `#` literally (e.g. API keys).
# Inline comments are stripped from unquoted values: `VAR=on  # comment` → `on`.
# Quoted values preserve `#`: `VAR="abc#123"` → `abc#123`.

# ─── Jira (required for mk:jira and 16 mk:jira-* leaves) ──
# Three vars consumed by `scripts/jira-as.sh` wrapper, which translates
# them into jira-as's native JIRA_* names + sets JIRA_OUTPUT=json default.
# Note on prefix: MEOW_JIRA_* uses the legacy MEOW_* style (one-off
# exception to the modern MEOWKIT_* convention) per migration directive.
# README upstream mentions JIRA_PROFILE — that's the broader Assistant
# Skills plugin layer concern, NOT jira-as itself; mk:jira does not consume it.
# Get an API token: https://id.atlassian.com/manage-profile/security/api-tokens
MEOW_JIRA_API_TOKEN=
MEOW_JIRA_EMAIL=
MEOW_JIRA_SITE_URL=

# ─── API Keys ───────────────────────────────────────────────
# Gemini (required for analysis + Gemini generation)
# Get from: https://aistudio.google.com/apikey
# MEOWKIT_GEMINI_API_KEY=
# Additional keys for rate-limit rotation (PLANNED — no consumer code yet)
# MEOWKIT_GEMINI_API_KEY_2=
# MEOWKIT_GEMINI_API_KEY_3=
# MEOWKIT_GEMINI_API_KEY_4=

# MiniMax (optional — image, video/Hailuo, TTS, music generation)
# Get from: https://platform.minimax.io/
# MEOWKIT_MINIMAX_API_KEY=

# OpenRouter (optional — image gen fallback when Google billing fails)
# Get from: https://openrouter.ai/keys
# MEOWKIT_OPENROUTER_API_KEY=
# MEOWKIT_OPENROUTER_FALLBACK_ENABLED=true

# ─── Provider Routing ──────────────────────────────────────
# Override provider fallback chains (comma-separated)
# MEOWKIT_IMAGE_PROVIDER_CHAIN=gemini,minimax,openrouter
# MEOWKIT_VIDEO_PROVIDER_CHAIN=gemini,minimax
# MEOWKIT_SPEECH_PROVIDER_CHAIN=minimax
# MEOWKIT_MUSIC_PROVIDER_CHAIN=minimax

# ─── Model Overrides ──────────────────────────────────────
# MEOWKIT_IMAGE_GEN_MODEL=gemini-3.1-flash-image-preview
# MEOWKIT_VIDEO_GEN_MODEL=veo-3.1-generate-preview
# MEOWKIT_MINIMAX_IMAGE_MODEL=image-01
# MEOWKIT_MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3
# MEOWKIT_MINIMAX_SPEECH_MODEL=speech-2.8-hd
# MEOWKIT_MINIMAX_MUSIC_MODEL=music-2.6
# MEOWKIT_MINIMAX_SPEECH_VOICE=Wise_Woman
# MEOWKIT_OPENROUTER_IMAGE_MODEL=black-forest-labs/flux-1-schnell

# ─── Core ───────────────────────────────────────────────────
# NOTE: Most core defaults now live in .claude/settings.json "env" block
# (team-shared, git-committed). Uncomment here ONLY to override per-project.
#
# TDD enforcement: 1 = strict red-green-refactor, 0 = off (default)
# MEOWKIT_TDD=0

# Hook profile: standard (default), fast (skip non-critical), strict (all hooks)
# New name: MEOWKIT_HOOK_PROFILE (MEOWKIT_* prefix consistency)
# Legacy name: MEOW_HOOK_PROFILE (still accepted; new name wins if both set)
# MEOWKIT_HOOK_PROFILE=standard

# Model hint fallback (only if auto-detection fails)
# MEOWKIT_MODEL_HINT=

# ─── Harness (Autonomous Build) ─────────────────────────────
# Override scaffolding density: MINIMAL | FULL | LEAN
# MEOWKIT_AUTOBUILD_MODE=

# Budget warning threshold in USD
# MEOWKIT_BUDGET_WARN=30

# Budget hard block threshold in USD
# MEOWKIT_BUDGET_BLOCK=100

# User budget cap override (can be lower or higher than BUDGET_BLOCK)
# MEOWKIT_BUDGET_CAP=


# ─── Memory ─────────────────────────────────────────────────
# Max chars injected by memory-loader per prompt (~1K tokens)
# MEOWKIT_MEMORY_BUDGET=4000

# Skip memory entries older than N months (default 6)
# MEOWKIT_MEMORY_STALENESS_MONTHS=6

# project-context.md byte cap at SessionStart. Files larger than this are
# truncated BEFORE injection (warning emitted). Default 12288 (~12KB ≈ ~3K tokens),
# aligning with BMAD-METHOD spec-budget research. Set to 0 to disable the cap.
# MEOWKIT_MAX_PROJECT_CONTEXT_BYTES=12288

# Agent-detector safety/phase-zero sentinel. Skips the 10-file rule-load on
# turns 2..N of the same session — files were already verified on turn 1 and
# cannot have been deleted without the user noticing. Set "off" to force the
# full 10-file Read on every turn (safe but ~9,700 tokens of overhead each turn).
# MEOWKIT_SKIP_SAFETY_SENTINEL=on

# Auto-prune memory .md topic files on Stop. Entries with a parseable
# YYYY-MM-DD date in their "## " header older than N days are removed.
# Entries with `severity: critical` or `severity: security` are NEVER pruned.
# Entries without a date are NEVER pruned (conservative — protects manual notes).
# JSON sidecars are out of scope. Set "off" to disable entirely.
# MEOWKIT_MEMORY_PRUNE=on
# MEOWKIT_MEMORY_PRUNE_AGE_DAYS=90


# ─── Hook Controls ──────────────────────────────────────────
# Set "off" to disable individual hooks
# MEOWKIT_BUILD_VERIFY=on
# MEOWKIT_LOOP_DETECT=on
# MEOWKIT_PRECOMPLETION=on
# MEOWKIT_TDD_FLAG_DETECTOR=on
