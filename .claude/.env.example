# MeowKit Environment Variables
# Copy to .claude/.env and fill in values.
# .env is gitignored — secrets stay local.
# Vars set here do NOT override shell exports (export VAR=x takes precedence).

# ─── API Keys ───────────────────────────────────────────────
# Required by meow:multimodal (vision, image/video generation)
# Get one at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# ─── Core ───────────────────────────────────────────────────
# TDD enforcement: 1 = strict red-green-refactor, off = default (recommended)
# MEOWKIT_TDD=off

# Hook profile: standard (default), fast (skip non-critical), strict (all hooks)
# MEOW_HOOK_PROFILE=standard

# Model hint fallback (only if auto-detection fails)
# MEOWKIT_MODEL_HINT=

# ─── Harness (Autonomous Build) ─────────────────────────────
# Override scaffolding density: MINIMAL | FULL | LEAN
# MEOWKIT_HARNESS_MODE=

# Budget warning threshold in USD
# MEOWKIT_BUDGET_WARN=30

# Budget hard block threshold in USD
# MEOWKIT_BUDGET_BLOCK=100

# User budget cap override (can be lower or higher than BUDGET_BLOCK)
# MEOWKIT_BUDGET_CAP=

# ─── Conversation Summary ───────────────────────────────────
# Disable: set to "off"
# MEOWKIT_SUMMARY_CACHE=on

# Min transcript bytes before summarization
# MEOWKIT_SUMMARY_THRESHOLD=20480

# Min JSONL events between summaries (~3-6 turns)
# MEOWKIT_SUMMARY_TURN_GAP=30

# Min transcript growth bytes between summaries
# MEOWKIT_SUMMARY_GROWTH_DELTA=5120

# ─── Memory ─────────────────────────────────────────────────
# Max chars injected by memory-loader per prompt (~1K tokens)
# MEOWKIT_MEMORY_BUDGET=4000

# ─── Hook Controls ──────────────────────────────────────────
# Set "off" to disable individual hooks
# MEOWKIT_BUILD_VERIFY=on
# MEOWKIT_LOOP_DETECT=on
# MEOWKIT_PRECOMPLETION=on
# MEOWKIT_TDD_FLAG_DETECTOR=on
