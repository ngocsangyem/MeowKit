# MeowKit Environment Variables
# Copy to .claude/.env and fill in values.
# .env is gitignored — secrets stay local.
# Vars set here do NOT override shell exports (export VAR=x takes precedence).

# ─── Jira (required for meow:jira) ──────────────────────────
# NOTE: These vars are for shell export reference only.
# Claude Code .mcp.json does NOT auto-load .env files.
# Use `claude mcp add -e KEY=val` or edit .mcp.json directly.
# Jira Cloud URL
# JIRA_URL=https://your-company.atlassian.net
# Jira account email
# JIRA_USERNAME=your-email@company.com
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_API_TOKEN=
# Optional: restrict visible projects (comma-separated)
# JIRA_PROJECTS_FILTER=
# Optional: block all write operations
# JIRA_READ_ONLY_MODE=false

# ─── API Keys ───────────────────────────────────────────────
# Gemini (required for analysis + Gemini generation)
# Get from: https://aistudio.google.com/apikey
# MEOWKIT_GEMINI_API_KEY=
# Additional keys for rate-limit rotation (optional)
# MEOWKIT_GEMINI_API_KEY_2=
# MEOWKIT_GEMINI_API_KEY_3=
# MEOWKIT_GEMINI_API_KEY_4=

# MiniMax (optional — image, video/Hailuo, TTS, music generation)
# Get from: https://platform.minimax.io/
# MEOWKIT_MINIMAX_API_KEY=

# OpenRouter (optional — image gen fallback when Google billing fails)
# Get from: https://openrouter.ai/keys
# MEOWKIT_OPENROUTER_API_KEY=
# MEOWKIT_OPENROUTER_FALLBACK_ENABLED=true

# ─── Provider Routing ──────────────────────────────────────
# Override provider fallback chains (comma-separated)
# MEOWKIT_IMAGE_PROVIDER_CHAIN=gemini,minimax,openrouter
# MEOWKIT_VIDEO_PROVIDER_CHAIN=gemini,minimax
# MEOWKIT_SPEECH_PROVIDER_CHAIN=minimax
# MEOWKIT_MUSIC_PROVIDER_CHAIN=minimax

# ─── Model Overrides ──────────────────────────────────────
# MEOWKIT_IMAGE_GEN_MODEL=gemini-3.1-flash-image-preview
# MEOWKIT_VIDEO_GEN_MODEL=veo-3.1-generate-preview
# MEOWKIT_MINIMAX_IMAGE_MODEL=image-01
# MEOWKIT_MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3
# MEOWKIT_MINIMAX_SPEECH_MODEL=speech-2.8-hd
# MEOWKIT_MINIMAX_MUSIC_MODEL=music-2.6
# MEOWKIT_MINIMAX_SPEECH_VOICE=Wise_Woman
# MEOWKIT_OPENROUTER_IMAGE_MODEL=black-forest-labs/flux-1-schnell

# ─── Core ───────────────────────────────────────────────────
# TDD enforcement: 1 = strict red-green-refactor, off = default (recommended)
# MEOWKIT_TDD=off

# Hook profile: standard (default), fast (skip non-critical), strict (all hooks)
# MEOW_HOOK_PROFILE=standard

# Model hint fallback (only if auto-detection fails)
# MEOWKIT_MODEL_HINT=

# ─── Harness (Autonomous Build) ─────────────────────────────
# Override scaffolding density: MINIMAL | FULL | LEAN
# MEOWKIT_HARNESS_MODE=

# Budget warning threshold in USD
# MEOWKIT_BUDGET_WARN=30

# Budget hard block threshold in USD
# MEOWKIT_BUDGET_BLOCK=100

# User budget cap override (can be lower or higher than BUDGET_BLOCK)
# MEOWKIT_BUDGET_CAP=

# ─── Conversation Summary ───────────────────────────────────
# Disable: set to "off"
# MEOWKIT_SUMMARY_CACHE=on

# Min transcript bytes before summarization
# MEOWKIT_SUMMARY_THRESHOLD=20480

# Min JSONL events between summaries (~3-6 turns)
# MEOWKIT_SUMMARY_TURN_GAP=30

# Min transcript growth bytes between summaries
# MEOWKIT_SUMMARY_GROWTH_DELTA=5120

# ─── Memory ─────────────────────────────────────────────────
# Max chars injected by memory-loader per prompt (~1K tokens)
# MEOWKIT_MEMORY_BUDGET=4000

# ─── Hook Controls ──────────────────────────────────────────
# Set "off" to disable individual hooks
# MEOWKIT_BUILD_VERIFY=on
# MEOWKIT_LOOP_DETECT=on
# MEOWKIT_PRECOMPLETION=on
# MEOWKIT_TDD_FLAG_DETECTOR=on
