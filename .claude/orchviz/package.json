{
  "name": "orchviz",
  "version": "0.1.0",
  "private": true,
  "description": "MeowKit Orchestration Visualization — real-time agent orchestration dashboard",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n relay,web \"npm run dev:relay\" \"npm run dev:web\"",
    "dev:relay": "npx tsx scripts/server.ts --workspace ../.. --open",
    "dev:web": "cd web && npm run dev",
    "build:relay": "node scripts/build-relay.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "ts-node": "^10.9.0",
    "esbuild": "^0.21.0",
    "concurrently": "^9.0.0"
  },
  "dependencies": {}
}
