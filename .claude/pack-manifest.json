{
  "schemaVersion": "1.0",
  "base": {
    "files": [
      "CLAUDE.md",
      "settings.json",
      "statusline.cjs",
      "workflow.yaml",
      "harness-inventory.json",
      "pack-manifest.json",
      "gitignore.meowkit",
      "mcp.json.example",
      ".env.example",
      "rules/security-rules.md",
      "rules/injection-rules.md",
      "rules/gate-rules.md",
      "rules/core-behaviors.md",
      "rules/development-rules.md"
    ],
    "globs": [
      "hooks/**",
      "scripts/**",
      "schemas/**",
      "memory/**",
      "agent-memory/**",
      "modes/**",
      "rubrics/**",
      "rules-conditional/**"
    ],
    "commands": ["plan", "upgrade", "validate", "status", "cook", "fix"]
  },
  "packs": {
    "lifecycle-core": {
      "owners": ["lifecycle"],
      "artifactsExclude": [
        "mk:autobuild",
        "autobuild",
        "mk:planning-engine",
        "mk:plan-ceo-review",
        "mk:story-sizer",
        "story-sizer",
        "mk:sprint-contract"
      ]
    },
    "testing": { "owners": ["testing"] },
    "git": { "owners": ["git"] },
    "docs": { "owners": ["docs"] },
    "memory": { "owners": ["memory"] },
    "research": { "owners": ["research"] },
    "portability": { "owners": ["portability"] },
    "observability": { "owners": ["observability"] },
    "utility": { "owners": ["utility"] },
    "security-audit": { "owners": ["security"] },
    "atlassian": { "owners": ["jira", "confluence"] },
    "product": {
      "artifactsAdd": [
        "mk:autobuild",
        "autobuild",
        "mk:planning-engine",
        "mk:plan-ceo-review",
        "mk:story-sizer",
        "story-sizer",
        "mk:sprint-contract",
        "mk:intake",
        "mk:office-hours"
      ]
    }
  },
  "profiles": {
    "core": ["base", "lifecycle-core", "memory", "utility"],
    "developer": ["core", "testing", "git", "docs"],
    "product": ["developer", "product"],
    "atlassian": ["developer", "atlassian"],
    "security": ["core", "security-audit"],
    "research": ["core", "research"],
    "full": ["*"]
  }
}
