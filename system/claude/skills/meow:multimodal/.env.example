# Google Gemini API Key (required)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model overrides (optional — sensible defaults used if not set)
# Analysis: gemini-2.5-flash (default), gemini-2.5-pro (advanced)
# MULTIMODAL_MODEL=gemini-2.5-flash

# Image generation: imagen-4.0-generate-001 (default), gemini-2.5-flash-image (fast)
# IMAGE_GEN_MODEL=imagen-4.0-generate-001

# Video generation: veo-3.1-generate-preview (default)
# VIDEO_GEN_MODEL=veo-3.1-generate-preview

# Output directory for generated files
# OUTPUT_DIR=./output

# Debug mode
# DEBUG=false
