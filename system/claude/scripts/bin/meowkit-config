#!/usr/bin/env bash
# meowkit-config — read/write .meowkit.config.json values
# Adapted from gstack-config for MeowKit. Uses project-local config, not ~/.gstack/.
# Usage:
#   meowkit-config get <key>
#   meowkit-config set <key> <value>
set -euo pipefail

CONFIG_FILE="${MEOWKIT_CONFIG:-.meowkit.config.json}"

case "${1:-}" in
  get)
    KEY="${2:?Usage: meowkit-config get <key>}"
    if [ -f "$CONFIG_FILE" ]; then
      python3 -c "import json,sys; d=json.load(open('$CONFIG_FILE')); print(d.get('$KEY',''))" 2>/dev/null || true
    fi
    ;;
  set)
    KEY="${2:?Usage: meowkit-config set <key> <value>}"
    VALUE="${3:?Usage: meowkit-config set <key> <value>}"
    if [ -f "$CONFIG_FILE" ]; then
      python3 -c "
import json
with open('$CONFIG_FILE') as f: d=json.load(f)
d['$KEY']='$VALUE'
with open('$CONFIG_FILE','w') as f: json.dump(d,f,indent=2)
" 2>/dev/null
    fi
    ;;
  *)
    echo "Usage: meowkit-config {get|set} <key> [value]"
    exit 1
    ;;
esac
